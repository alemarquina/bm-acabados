---
import Layout from "../../layouts/Layout.astro";
import Container from "../../layouts/Container.astro";
import MainTitle from "../../components/ui/MainTitle.astro";
import { services } from "../../content/services";
import { Image } from "astro:assets";
---

<Layout title="Servicios — BM Acabados">
  <!-- Header de la página -->
  <section class="w-full bg-blueDark py-16">
    <Container>
      <div class="flex flex-col items-start space-y-2">
        <h1 class="text-3xl md:text-5xl font-extrabold text-white">
          Nuestros <span class="text-goldenSecondary">Servicios</span>
        </h1>
        <p class="text-white/80 max-w-xl">
          Contamos con un equipo especializado para cada tipo de trabajo.
          Calidad y profesionalismo en cada proyecto.
        </p>
      </div>
    </Container>
  </section>

  <!-- Grilla de servicios -->
  <section class="py-14">
    <Container>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          services.map((service) => (
            <a
              href={`/servicios/${service.slug}`}
              class="group flex flex-col rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow duration-200 bg-white"
            >
              <div class="overflow-hidden h-48">
                <Image
                  src={service.image}
                  alt={service.title}
                  width={500}
                  height={300}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-5 flex flex-col space-y-2 flex-1">
                <MainTitle nameTitle={service.title} />
                <p class="text-darkText text-sm flex-1">
                  {service.shortDescription}
                </p>
                <span class="text-goldenPrimary text-sm font-semibold group-hover:underline">
                  Ver más →
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </Container>
  </section>
</Layout>
