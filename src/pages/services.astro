---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import Container from "../layouts/Container.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import { services } from "../content/services";
import MainTitle from "../components/ui/MainTitle.astro";
import ButtonGolden from "../components/ui/ButtonGolden.astro";
import YellowCard from "../components/ui/YellowCard.astro";
import BenefitImage1 from "../assets/services/benefit_1.webp";
import BenefitImage2 from "../assets/services/benefit_2.webp";
import BenefitImage3 from "../assets/services/benefit_3.webp";
import BenefitImage4 from "../assets/services/benefit_4.webp";
---

<Layout title="Servicios — BM Acabados">
  <section
    class="relative overflow-hidden bg-gradient-to-br bg-bluePrimary via-zinc-900 to-blueDark py-6 sm:py-10 border-b border-zinc-800 text-white w-full"
    data-scroll-reveal
  >
    <div
      class="absolute -right-20 -top-20 w-80 h-80 bg-goldenPrimary/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div
      class="absolute -left-20 -bottom-20 w-80 h-80 bg-blueDark/20 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <Container>
      <div
        class="relative z-10 max-w-2xl mx-auto text-center space-y-4"
        data-reveal-header
      >
        <span
          class="text-goldenSecondary font-semibold tracking-widest text-[0.7rem] uppercase font-poppins bg-white/5 border border-white/10 py-1 px-3 rounded-full backdrop-blur-sm shadow-sm inline-block"
        >
          Excelencia en Revestimientos
        </span>

        <h1
          class="text-2xl sm:text-4xl font-extrabold tracking-tight font-encode-sans text-white leading-tight"
        >
          Nuestros <span class="text-goldenSecondary">Servicios</span>
        </h1>

        <div class="h-[2px] w-12 bg-goldenPrimary mx-auto rounded-full"></div>

        <p
          class="text-zinc-300 text-xs sm:text-sm leading-relaxed font-poppins max-w-xl mx-auto"
        >
          Ofrecemos servicios generales especializados en acabados y
          revestimientos para todo tipo de espacios, combinando funcionalidad y
          estética de excelencia.
        </p>
      </div>
    </Container>
  </section>

  <!-- Listado de Servicios -->
  <section>
    <div class="py-14 sm:py-20 bg-zinc-50 min-h-screen">
      <Container>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 justify-items-center"
        >
          {
            services.map((service) => (
              <ServiceCard
                slug={service.slug}
                title={service.title}
                shortDescription={service.shortDescription}
                image={service.image}
                icon={service.icon}
              />
            ))
          }
        </div>
      </Container>
    </div>
    <div class="h-2 bg-goldenSecondary"></div>
  </section>

  <section>
    <div class="bg-bluePrimary" data-scroll-reveal>
      <Container>
        <div
          class="flex flex-col items-center justify-center space-y-8 py-12"
          data-reveal-header
        >
          <div>
            <MainTitle
              nameTitle="¡Contáctanos para hacer una visita técnica!"
              class="text-white"
            />
          </div>
          <div>
            <ButtonGolden nameButton="Contactar" route="/#contacto" />
          </div>
          <div>
            <p class="text-white">
              Contáctanos para poder agendar una visita técnica completamente
              gratis y sin compromiso. Te vamos a asesorar en todo momento y
              brindarte soluciones óptimas para modernizar y realzar tus
              espacios
            </p>
          </div>
          <div
            class="grid grid-cols-1 gap-4 min-[425px]:grid-cols-2 min-[425px]:gap-6 md:grid-cols-4 xl:gap-12 items-center justify-center"
          >
            <YellowCard
              benefit="Calidad\ngarantizada"
              image={BenefitImage1}
              alt="Icon BM"
              class="h-24 w-36 lg:h-32 lg:w-52"
            />
            <YellowCard
              benefit="Entrega\npuntual"
              image={BenefitImage2}
              alt="Icon BM"
              width={50}
              height={50}
              class="h-24 w-36 lg:h-32 lg:w-52"
            />
            <YellowCard
              benefit="Asesoramiento\nintegral"
              image={BenefitImage3}
              alt="Icon BM"
              width={60}
              height={60}
              class="h-24 w-36 lg:h-32 lg:w-52"
            />
            <YellowCard
              benefit="Resultados\nduraderos"
              image={BenefitImage4}
              alt="Icon BM"
              width={50}
              height={50}
              class="h-24 w-36 lg:h-32 lg:w-52"
            />
          </div>
        </div>
      </Container>
    </div>
  </section></Layout
>
