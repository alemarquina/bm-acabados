---
interface Props {
  type: "email" | "phone";
  class?: string;
}

const { type, class: className = "" } = Astro.props;
---

{
  type === "email" && (
    <a
      href="mailto:bmacabadosgrp@gmail.com"
      class={`w-10 h-10 rounded-full bg-goldenSecondary hover:bg-goldenPrimary active:scale-95 transition-all flex items-center justify-center text-white shadow-[0_2px_8px_rgba(0,0,0,0.15)] flex-shrink-0 ${className}`}
      aria-label="Enviar correo electrónico"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        />
      </svg>
    </a>
  )
}

{
  type === "phone" && (
    <a
      href="tel:+51937343082"
      class={`w-10 h-10 rounded-full bg-goldenSecondary hover:bg-goldenPrimary active:scale-95 transition-all flex items-center justify-center text-white shadow-[0_2px_8px_rgba(0,0,0,0.15)] flex-shrink-0 ${className}`}
      aria-label="Llamar por teléfono"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6 fill-current"
        viewBox="0 0 24 24"
      >
        <path d="M20 15.5c-1.2 0-2.4-.2-3.6-.6-.3-.1-.7 0-1 .2l-2.2 2.2c-2.8-1.4-5.1-3.8-6.6-6.6l2.2-2.2c.3-.3.4-.7.2-1-.3-1.1-.5-2.3-.5-3.5 0-.6-.4-1-1-1H4c-.6 0-1 .4-1 1 0 9.4 7.6 17 17 17 .6 0 1-.4 1-1v-3.5c0-.6-.4-1-1-1z" />
      </svg>
    </a>
  )
}
