---
import ButtonGolden from "./ButtonGolden.astro";
import ContactMedia from "./ContactMedia.astro";
import SocialMedia from "./SocialMedia.astro";
---

<div
  class="w-full max-w-[640px] lg:max-w-none mx-auto grid grid-cols-1 lg:grid-cols-12 rounded-3xl overflow-hidden shadow-2xl bg-white border border-zinc-100/80"
>
  <!-- Panel Izquierdo: Información de Contacto (Dark) -->
  <div
    class="lg:col-span-5 bg-white text-blueText p-5 md:p-8 lg:p-12 flex flex-col justify-between gap-6"
  >
    <div class="space-y-4">
      <h3 class="text-2xl font-bold tracking-tight">Ponte en contacto</h3>
      <p class="text-sm text-blueText leading-relaxed font-medium">
        Comunicate con nosotros por nuestros diversos canales ya sea enviandonos
        un correo o llamandonos diréctamente para agendar una visita técnica
      </p>
    </div>

    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <ContactMedia type="email" />
        <span class="text-sm text-blueText">bmacabadosgrp@gmail.com</span>
      </div>
      <div class="flex items-center gap-2">
        <ContactMedia type="phone" />
        <span class="text-sm text-blueText">+51 932 356 235</span>
      </div>
    </div>

    <div class="space-y-4">
      <p class="text-sm text-blueText font-medium">
        Siguenos en nuestras redes sociales para que te enteres más sobre
        nosotros
      </p>
      <SocialMedia />
    </div>

    <p class="text-xs text-blueText tracking-wide">
      ¡Nosotros nos pondremos en contacto contigo lo más rápido posible!
    </p>
  </div>

  <!-- Panel Derecho: Formulario (Light) -->
  <form
    id="contact-form"
    class="lg:col-span-7 bg-zinc-100 p-5 md:p-8 lg:p-12 flex flex-col justify-between gap-8"
  >
    <div class="space-y-6">
      <h3 class="text-2xl font-bold text-blueText tracking-tight">
        Solicita una cotización gratis
      </h3>

      <!-- Contenedor para mensajes de éxito o error -->
      <div
        id="form-status"
        class="hidden p-4 rounded-xl text-sm font-semibold transition-all duration-300"
      >
      </div>

      <!-- Honeypot para evitar spam de bots -->
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

      <div class="space-y-4">
        <div class="space-y-2">
          <label
            for="nombres"
            class="block text-sm font-bold text-blueText opacity-95"
            >Nombres</label
          >
          <input
            type="text"
            id="nombres"
            name="nombres"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm shadow-sm"
          />
        </div>

        <div class="space-y-2">
          <label
            for="celular"
            class="block text-sm font-bold text-blueText opacity-95"
            >Número de Celular</label
          >
          <input
            type="tel"
            id="celular"
            name="celular"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm shadow-sm"
          />
          <span
            id="celular-error"
            class="text-xs text-red-500 hidden font-semibold"
          >
            El formato de celular debe ser: 9 dígitos (911222333), con código de
            país (51902260941) o separado por espacios (900 000 000).
          </span>
        </div>

        <div class="space-y-2">
          <label
            for="email"
            class="block text-sm font-bold text-blueText opacity-95"
            >Correo Electrónico</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm shadow-sm"
          />
        </div>

        <div class="space-y-2">
          <label
            for="mensaje"
            class="block text-sm font-bold text-blueText opacity-95"
            >Mensaje</label
          >
          <textarea
            id="mensaje"
            name="mensaje"
            rows="5"
            required
            placeholder="Describe el servicio que requieres..."
            class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm shadow-sm resize-none"
          ></textarea>
        </div>
      </div>
    </div>

    <ButtonGolden nameButton="Enviar" type="submit" />
  </form>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const statusContainer = document.getElementById(
    "form-status",
  ) as HTMLDivElement;
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement;

  const celularInput = document.getElementById("celular") as HTMLInputElement;
  const celularError = document.getElementById(
    "celular-error",
  ) as HTMLSpanElement;

  if (form && statusContainer && submitBtn && celularInput && celularError) {
    // Evitar que escriban o peguen letras u otros caracteres no permitidos
    celularInput.addEventListener("input", () => {
      // Permitir solo números y espacios
      celularInput.value = celularInput.value.replace(/[^0-9\s]/g, "");

      celularInput.classList.remove(
        "border-red-500",
        "focus:border-red-500",
        "focus:ring-red-500",
      );
      celularInput.classList.add(
        "border-zinc-200",
        "focus:border-goldenPrimary",
        "focus:ring-goldenPrimary",
      );
      celularError.classList.add("hidden");
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Limpiar estados anteriores
      statusContainer.classList.add("hidden");
      statusContainer.textContent = "";
      statusContainer.className =
        "hidden p-4 rounded-xl text-sm font-semibold transition-all duration-300";

      // Verificar cooldown (bloqueo por spam manual de 5 minutos)
      const lastSubmit = localStorage.getItem("contact_form_last_submit_time");
      const cooldownPeriod = 5 * 60 * 1000; // 5 minutos

      if (lastSubmit) {
        const timePassed = Date.now() - Number(lastSubmit);
        if (timePassed < cooldownPeriod) {
          const minutesLeft = Math.ceil((cooldownPeriod - timePassed) / 1000 / 60);
          
          statusContainer.classList.remove("hidden");
          statusContainer.classList.add("bg-amber-100", "text-amber-800", "border", "border-amber-200");
          statusContainer.textContent = `Por seguridad, debés esperar ${minutesLeft} minuto(s) para enviar otra solicitud. ¡Muchas gracias!`;
          return;
        }
      }

      // Deshabilitar botón y mostrar estado de carga
      submitBtn.disabled = true;
      const originalText = submitBtn.textContent || "Enviar";
      submitBtn.textContent = "Enviando...";

      // Validar celular peruano
      const celularValue = celularInput.value.trim();
      const celularRegex = /^(9\d{8}|519\d{8}|9\d{2}\s\d{3}\s\d{3})$/;

      if (!celularRegex.test(celularValue)) {
        celularInput.classList.remove("border-zinc-200", "focus:border-goldenPrimary", "focus:ring-goldenPrimary");
        celularInput.classList.add("border-red-500", "focus:border-red-500", "focus:ring-red-500");
        celularError.classList.remove("hidden");
        
        // Restaurar estado del botón
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        return;
      }

      try {
        const formData = new FormData(form);
        
        // Agregar la clave pública de Web3Forms desde las variables de entorno
        const apiKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "";
        formData.append("access_key", apiKey);
        formData.append("subject", "Nueva cotización desde BM Acabados Web");
        formData.append("from_name", "Contacto BM Acabados");

        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        });

        const result = await response.json();

        if (response.status === 200) {
          // Éxito
          statusContainer.classList.remove("hidden");
          statusContainer.classList.add(
            "bg-green-100",
            "text-green-800",
            "border",
            "border-green-200",
          );
          statusContainer.textContent =
            "¡Tu mensaje ha sido enviado con éxito! Nos pondremos en contacto contigo lo antes posible.";
          
          // Guardar marca de tiempo del envío exitoso
          localStorage.setItem("contact_form_last_submit_time", Date.now().toString());
          
          form.reset();
        } else {
          // Error devuelto por la API
          statusContainer.classList.remove("hidden");
          statusContainer.classList.add(
            "bg-red-100",
            "text-red-800",
            "border",
            "border-red-200",
          );
          statusContainer.textContent =
            result.message ||
            "Hubo un problema al enviar tu mensaje. Por favor, inténtalo de nuevo.";
        }
      } catch (error) {
        // Error de red
        statusContainer.classList.remove("hidden");
        statusContainer.classList.add(
          "bg-red-100",
          "text-red-800",
          "border",
          "border-red-200",
        );
        statusContainer.textContent =
          "Hubo un problema de conexión. Por favor, verifica tu red e inténtalo de nuevo.";
        console.error("Error al enviar el formulario:", error);
      } finally {
        // Restaurar estado del botón
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>
