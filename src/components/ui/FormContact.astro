---
import ButtonGolden from "./ButtonGolden.astro";
import ContactMedia from "./ContactMedia.astro";
import SocialMedia from "./SocialMedia.astro";
---

<div
  class="w-full max-w-[640px] lg:max-w-none mx-auto grid grid-cols-1 lg:grid-cols-12 rounded-3xl overflow-hidden shadow-2xl bg-white border border-zinc-100/80"
>
  <!-- Panel Izquierdo: Información de Contacto (Dark) -->
  <div
    class="lg:col-span-5 bg-white text-blueText p-5 md:p-8 lg:p-12 flex flex-col justify-between gap-6"
  >
    <div class="space-y-4">
      <h3 class="text-2xl font-bold tracking-tight">Ponte en contacto</h3>
      <p class="text-sm text-blueText leading-relaxed font-medium">
        Comunicate con nosotros por nuestros diversos canales ya sea enviandonos
        un correo o llamandonos diréctamente para agendar una visita técnica
      </p>
    </div>

    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <ContactMedia type="email" />
        <span class="text-sm text-blueText">bmacabadosgrp@gmail.com</span>
      </div>
      <div class="flex items-center gap-2">
        <ContactMedia type="phone" />
        <span class="text-sm text-blueText">+51 932 356 235</span>
      </div>
    </div>

    <div class="space-y-4">
      <p class="text-sm text-blueText font-medium">
        Siguenos en nuestras redes sociales para que te enteres más sobre
        nosotros
      </p>
      <SocialMedia />
    </div>

    <p class="text-xs text-blueText tracking-wide">
      ¡Nosotros nos pondremos en contacto contigo lo más rápido posible!
    </p>
  </div>

  <!-- Panel Derecho: Formulario (Light) -->
  <form
    class="lg:col-span-7 bg-zinc-100 p-5 md:p-8 lg:p-12 flex flex-col justify-between gap-8"
  >
    <div class="space-y-6">
      <h3 class="text-2xl font-bold text-blueText tracking-tight">
        Solicita una cotización gratis
      </h3>

      <div class="space-y-4">
        <div class="space-y-2">
          <label
            for="nombres"
            class="block text-sm font-bold text-blueText opacity-95"
            >Nombres</label
          >
          <input
            type="text"
            id="nombres"
            name="nombres"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm font-semibold shadow-sm"
          />
        </div>

        <div class="space-y-2">
          <label
            for="celular"
            class="block text-sm font-bold text-blueText opacity-95"
            >Número de Celular</label
          >
          <input
            type="tel"
            id="celular"
            name="celular"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm font-semibold shadow-sm"
          />
        </div>

        <div class="space-y-2">
          <label
            for="email"
            class="block text-sm font-bold text-blueText opacity-95"
            >Correo Electrónico</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm font-semibold shadow-sm"
          />
        </div>

        <div class="space-y-2">
          <label
            for="mensaje"
            class="block text-sm font-bold text-blueText opacity-95"
            >Mensaje</label
          >
          <textarea
            id="mensaje"
            name="mensaje"
            rows="5"
            required
            placeholder="Describe el servicio que requieres..."
            class="w-full px-4 py-3 bg-white border border-zinc-200 rounded-xl focus:outline-none focus:border-goldenPrimary focus:ring-1 focus:ring-goldenPrimary transition-colors text-zinc-800 text-sm shadow-sm resize-none"
          ></textarea>
        </div>
      </div>
    </div>

    <ButtonGolden nameButton="Enviar" type="submit" />
  </form>
</div>
