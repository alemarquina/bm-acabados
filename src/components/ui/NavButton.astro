---
interface Props {
  name: string;
  Icon: any;
  href?: string;
}

const { name, Icon, href = "#" } = Astro.props;
---

<a
  href={href}
  class="flex items-center space-x-4 py-2.5 px-7 w-full text-white hover:bg-zinc-900 duration-200 hover:text-white hover:font-medium"
>
  <Icon />
  <span>{name}</span>
</a>
