---
import { Image } from "astro:assets";
import { ChevronLeft, ChevronRight } from "lucide-astro";

import trabajo1 from "../../assets/works/trabajo-1.webp";
import trabajo2 from "../../assets/works/trabajo-3.webp";
import trabajo3 from "../../assets/works/trabajo-2.webp";
import trabajo4 from "../../assets/works/trabajo-4.png";

const works = [
  { src: trabajo1, alt: "Fachada de edificio con acabado en madera" },
  { src: trabajo2, alt: "Piso Laminado y Pintado de departamento" },
  { src: trabajo3, alt: "Renovación y pintado de madera de mampara" },
  { src: trabajo4, alt: "Sala con estuco veneciano y drywall" },
];
---

<!-- Carousel Container -->
<div id="carousel-container" class="relative group w-full min-[480px]:px-10">
  <!-- Navigation Buttons -->
  <button
    id="carousel-prev"
    class="absolute left-2 sm:-left-4 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white text-zinc-800 hover:text-goldenSecondary p-2 sm:p-3 rounded-full shadow-lg border border-zinc-200 backdrop-blur-sm transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100"
    aria-label="Trabajo anterior"
  >
    <ChevronLeft class="w-6 h-6" />
  </button>

  <button
    id="carousel-next"
    class="absolute right-2 sm:-right-4 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white text-zinc-800 hover:text-goldenSecondary p-2 sm:p-3 rounded-full shadow-lg border border-zinc-200 backdrop-blur-sm transition-all duration-300 opacity-0 group-hover:opacity-100 focus:opacity-100"
    aria-label="Siguiente trabajo"
  >
    <ChevronRight class="w-6 h-6" />
  </button>

  <!-- Carousel Track Wrapper -->
  <div
    class="overflow-hidden rounded-2xl shadow-md border border-zinc-200 bg-white p-4"
  >
    <div
      id="carousel-track"
      class="flex transition-transform duration-500 ease-in-out"
    >
      {
        works.map((work) => (
          <div class="w-full sm:w-2/3 md:w-1/3 lg:w-1/4 flex-shrink-0 px-2">
            <div class="relative overflow-hidden rounded-xl aspect-[4/3] sm:aspect-square bg-zinc-100 border border-zinc-200 group/item shadow-sm">
              <Image
                src={work.src}
                alt={work.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover/item:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover/item:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <p class="text-white text-xs font-semibold tracking-wider font-poppins uppercase">
                  {work.alt}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  const setupCarousel = (): void => {
    const track = document.getElementById("carousel-track");
    const prevBtn = document.getElementById("carousel-prev");
    const nextBtn = document.getElementById("carousel-next");
    const container = document.getElementById("carousel-container");

    if (!track || !prevBtn || !nextBtn || !container) return;

    const slides = Array.from(track.children) as HTMLElement[];
    let currentIndex: number = 0;
    let autoplayTimer: ReturnType<typeof setInterval> | undefined;

    const getVisibleSlides = (): number => {
      if (window.innerWidth >= 1024) return 4;
      if (window.innerWidth >= 768) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    };

    const updateCarousel = (): void => {
      const visibleSlides = getVisibleSlides();
      const maxIndex = slides.length - visibleSlides;

      // Keep current index in bounds
      if (currentIndex > maxIndex) {
        currentIndex = 0; // wrap to start
      } else if (currentIndex < 0) {
        currentIndex = Math.max(0, maxIndex); // wrap to end
      }

      const slideWidth = 100 / visibleSlides;
      const translation = currentIndex * slideWidth;

      track.style.transform = `translateX(-${translation}%)`;
    };

    const nextSlide = (): void => {
      const visibleSlides = getVisibleSlides();
      const maxIndex = slides.length - visibleSlides;
      if (currentIndex >= maxIndex) {
        currentIndex = 0;
      } else {
        currentIndex++;
      }
      updateCarousel();
    };

    const prevSlide = (): void => {
      const visibleSlides = getVisibleSlides();
      const maxIndex = slides.length - visibleSlides;
      if (currentIndex <= 0) {
        currentIndex = Math.max(0, maxIndex);
      } else {
        currentIndex--;
      }
      updateCarousel();
    };

    const startAutoplay = (): void => {
      stopAutoplay();
      autoplayTimer = setInterval(nextSlide, 3000);
    };

    const stopAutoplay = (): void => {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = undefined;
      }
    };

    // Event listeners
    nextBtn.addEventListener("click", (): void => {
      nextSlide();
      startAutoplay(); // Reset timer
    });

    prevBtn.addEventListener("click", (): void => {
      prevSlide();
      startAutoplay(); // Reset timer
    });

    // Pause on hover
    container.addEventListener("mouseenter", (): void => {
      stopAutoplay();
    });
    container.addEventListener("mouseleave", (): void => {
      startAutoplay();
    });

    // Update on resize
    window.addEventListener("resize", (): void => {
      updateCarousel();
    });

    // Initialize
    updateCarousel();
    startAutoplay();
  };

  // Run on load
  setupCarousel();

  // Re-run on view transitions if using them
  document.addEventListener("astro:page-load", (): void => {
    setupCarousel();
  });
</script>
