<div
  id="stats-container"
  class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 text-center"
>
  <div class="flex flex-col items-center">
    <span
      class="text-3xl md:text-4xl font-extrabold tracking-tight text-white stats-counter"
      data-target="15"
      data-suffix="+"
    >
      15+
    </span>
    <span class="text-sm md:text-base mt-2 text-white">Años de experiencia</span
    >
  </div>
  <div class="flex flex-col items-center">
    <span
      class="text-3xl md:text-4xl font-extrabold tracking-tight text-white stats-counter"
      data-target="155"
      data-suffix="+"
    >
      155+
    </span>
    <span class="text-sm md:text-base mt-2 text-white"
      >Trabajos Completados</span
    >
  </div>
  <div class="flex flex-col items-center">
    <span
      class="text-3xl md:text-4xl font-extrabold tracking-tight text-white stats-counter"
      data-target="96"
      data-suffix="%"
    >
      96%
    </span>
    <span class="text-sm md:text-base mt-2 text-white"
      >Clientes satisfechos</span
    >
  </div>
</div>

<script>
  const DURATION = 1200; // 1.2 segundos

  function animateCounters(
    entries: IntersectionObserverEntry[],
    observer: IntersectionObserver,
  ) {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const counters = entry.target.querySelectorAll(".stats-counter");
        counters.forEach((counterEl) => {
          const counter = counterEl as HTMLElement;
          const target = parseInt(counter.dataset.target || "0", 10);
          const suffix = counter.dataset.suffix || "";

          let startTimestamp: number | null = null;

          // Progressive enhancement: inicializar a 0 antes de empezar
          counter.textContent = "0" + suffix;

          function step(timestamp: number) {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min(
              (timestamp - startTimestamp) / DURATION,
              1,
            );
            const currentValue = Math.floor(progress * target);
            counter.textContent = currentValue + suffix;

            if (progress < 1) {
              window.requestAnimationFrame(step);
            } else {
              counter.textContent = target + suffix;
            }
          }

          window.requestAnimationFrame(step);
        });
        // Dejar de observar una vez iniciada la animación
        observer.unobserve(entry.target);
      }
    });
  }

  // Esperar a que el DOM esté disponible
  const statsContainer = document.getElementById("stats-container");
  if (statsContainer) {
    const observer = new IntersectionObserver(animateCounters, {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px",
    });
    observer.observe(statsContainer);
  }
</script>
