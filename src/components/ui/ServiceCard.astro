---
const { imageService, title, descrip, iconImage } = Astro.props;
import { ArrowRight } from "lucide-astro";
---

<article class="flex flex-col bg-white rounded-xl shadow-md overflow-hidde mx-8 max-w-60 [clip-path:polygon(0_20%,_100%_-70%,_100%_100%,_0%_100%)]">
  <div class="relative w-full">
    <img class="block w-full object-cover" src={imageService} alt="Servicio 1" />        
    <div class="absolute -bottom-6 left-4">              
      <img class="bg-goldenPrimary p-2 rounded-full h-12 w-12 border-4 border-white shadow-sm" src={iconImage} alt="Icono de Carta" />      
    </div>
  </div>  
  <div class="pt-7 pb-3 px-4 space-y-2">
    <h5 class="text-lg font-semibold">{title}</h5>
    <p class="text-gray-600 text-sm">{descrip}</p>
    <a href="#" class="text-blueText flex space-x-1 items-center text-sm">Ver Más<ArrowRight size="18"/></a>
  </div>
</article>
