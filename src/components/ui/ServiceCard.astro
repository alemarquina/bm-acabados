---
import { Image } from "astro:assets";
import { ArrowRight } from "lucide-astro";
import type { Service } from "../../content/services";

type Props = Pick<Service, "slug" | "title" | "shortDescription" | "image" | "icon">;

const { slug, title, shortDescription, image, icon } = Astro.props;
---

<article class="flex flex-col bg-white rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.08)] overflow-hidden w-full max-w-[320px] transition-all duration-250 ease-in-out hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(0,34,81,0.14)]">  
  <div class="relative w-full aspect-[5/3]">
    <Image
      src={image}
      alt={title}
      width={300}
      height={240}
      class="block w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute -bottom-6 left-4 bg-goldenPrimary border-4 border-white rounded-full w-12 h-12 flex items-center justify-center shadow-[0_2px_8px_rgba(0,0,0,0.15)]">
      <Image
        src={icon}
        alt={`Ícono de ${title}`}
        width={32}
        height={32}
        class="w-7 h-7 object-contain"
      />
    </div>
  </div>

  <!-- Contenido textual -->
  <div class="pt-8 px-5 pb-5 flex flex-col gap-2 flex-1">
    <h3 class="text-[1.1rem] font-bold text-blueText leading-[1.3]">{title}</h3>
    <p class="text-sm text-darkText leading-[1.6] flex-1">{shortDescription}</p>
    <a href={`/servicios/${slug}`} class="inline-flex items-center gap-1 text-sm font-semibold text-blueText no-underline mt-1 transition-all duration-200 hover:text-goldenPrimary hover:gap-2">
      Ver Más <ArrowRight size={16} />
    </a>
  </div>
</article>
