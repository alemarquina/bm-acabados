---
interface Props {
  name?: string;
  nameButton?: string;
  route?: string;
  class?: string;
  type?: "button" | "submit" | "reset";
}

const { name, nameButton, route, class: className, type = "button" } = Astro.props;
const label = name || nameButton;
const Tag = route ? 'a' : 'button';
---

<Tag
  href={route}
  type={route ? undefined : type}
  class="flex min-w-36 justify-center py-2 bg-zinc-100 hover:bg-white duration-200 rounded-full text-zinc-800 font-semibold items-center text-center cursor-pointer"
  class:list={[className]}
>
  {label}
</Tag>
